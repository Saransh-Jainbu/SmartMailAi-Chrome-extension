{
    "manifest_version": 3,
    "name": "SmartMail AI",
    "version": "1.1.0",
    "description": "AI email assistant for Gmail and Outlook. Brings priority scoring, one-sentence summaries, and AI reply drafting to your inbox. Bring your own OpenAI or Anthropic key — your email never leaves your browser.",
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
    ],
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://mail.google.com/*",
                "https://outlook.live.com/*",
                "https://outlook.office.com/*",
                "https://outlook.office365.com/*",
                "https://*.outlook.com/*",
                "https://*.office.com/*"
            ],
            "js": [
                "assets/content.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}